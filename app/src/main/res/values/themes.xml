<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.ClearSpace" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/b800</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/sage</item>
        <item name="android:statusBarColor">@color/appBg</item>
        <item name="android:navigationBarColor">@color/appBg</item>
        <item name="android:windowBackground">@color/appBg</item>
    </style>

    <style name="Theme.ClearSpace" parent="Base.Theme.ClearSpace" />

    <!-- Time Chip Style -->
    <style name="TimeChipStyle" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">40dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Bottom Navigation Indicator -->
    <style name="BottomNavIndicator" parent="">
        <item name="android:color">@color/b100</item>
    </style>

</resources>
