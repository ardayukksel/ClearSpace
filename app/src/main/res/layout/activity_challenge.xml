<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/challengeBg"
    android:padding="32dp">

    <TextView
        android:id="@+id/tv_challenge_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pause &amp; Reflect"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/challengeText"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_challenge_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Complete the challenge before you continue."
        android:textSize="16sp"
        android:textColor="@color/challengeSubtext"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginBottom="40dp" />

    <TextView
        android:id="@+id/tv_phase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Breathe In"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/challengeText"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4"
        android:textSize="92sp"
        android:textStyle="bold"
        android:textColor="@color/challengeText"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Challenge progress"
        android:textSize="15sp"
        android:textColor="@color/challengeSubtext"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/et_answer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:hint="Enter answer"
        android:inputType="numberSigned"
        android:paddingHorizontal="16dp"
        android:textColor="@color/challengeText"
        android:textColorHint="@color/challengeSubtext"
        android:backgroundTint="@color/challengeButton"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_action"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Action"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/challengeButton"
        android:textColor="@color/challengeButtonText"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_unlock"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Unlock App"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/challengeButton"
        android:textColor="@color/challengeButtonText"
        android:visibility="gone" />

</LinearLayout>