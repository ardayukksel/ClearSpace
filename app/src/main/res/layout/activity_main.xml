<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#F5F4F0"> <TextView
    android:id="@+id/tv_selected_app"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Target App: None"
    android:textSize="20sp"
    android:textStyle="bold"
    android:textColor="#4A3B32"
    android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_select_app"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CHOOSE APP TO BLOCK"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        android:backgroundTint="#A0A0A0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <Switch
        android:id="@+id/switch_target_app"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Enable Blocking"
        android:textColor="#4A3B32"
        android:textSize="18sp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tv_session_limit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Session Limit: 10 min"
        android:textColor="#8C8C8C"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <SeekBar
        android:id="@+id/seekbar_session"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="60"
        android:progress="10"
        android:progressTint="#4A3B32"
        android:thumbTint="#4A3B32"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SAVE SETTINGS"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        android:backgroundTint="#4A3B32"
        android:textColor="#FFFFFF"/>

</LinearLayout>