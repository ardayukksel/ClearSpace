<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#F5F4F0"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="MY DASHBOARD"
    android:textSize="28sp"
    android:textStyle="bold"
    android:letterSpacing="0.1"
    android:textColor="#4A3B32"
    android:layout_marginBottom="40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="32dp"
        android:gravity="center"
        android:elevation="2dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time Saved Today"
            android:textSize="18sp"
            android:textColor="#8C8C8C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45 mins"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="#4A3B32"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus on what truly matters."
        android:textSize="18sp"
        android:textStyle="italic"
        android:textColor="#8C8C8C"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BACK TO SETTINGS"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        android:backgroundTint="#4A3B32"
        android:textColor="#FFFFFF" />

</LinearLayout>