<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title with emoji -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Commitment"
                android:textSize="28sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Subtitle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Write a personal pledge. This will be shown on your dashboard as a daily reminder. 🌱"
                android:textSize="16sp"
                android:textColor="@color/textSecondary"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- Commitment Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/et_commitment"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@android:color/transparent"
                    android:hint="I will..."
                    android:textColorHint="@color/muted"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:gravity="top"
                    android:maxLength="160"
                    android:inputType="textMultiLine"
                    android:padding="0dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Character count and privacy note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your commitment stays private"
                android:textSize="12sp"
                android:textColor="@color/muted" />

            <TextView
                android:id="@+id/tv_char_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/160"
                android:textSize="12sp"
                android:textColor="@color/muted" />

        </LinearLayout>

        <!-- Inspiration Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌾"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Need inspiration? Tap one:"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Inspiration Option 1 -->
            <LinearLayout
                android:id="@+id/btn_inspiration_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_inspiration_card"
                android:padding="16dp"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&quot;I will be more present with the people around me.&quot;"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Inspiration Option 2 -->
            <LinearLayout
                android:id="@+id/btn_inspiration_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_inspiration_card"
                android:padding="16dp"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&quot;I will spend less time scrolling and more time doing.&quot;"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Inspiration Option 3 -->
            <LinearLayout
                android:id="@+id/btn_inspiration_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_inspiration_card"
                android:padding="16dp"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&quot;I will check my phone intentionally, not out of habit.&quot;"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

        </LinearLayout>

        <!-- Skip Button -->
        <LinearLayout
            android:id="@+id/btn_skip"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skip for now >"
                android:textSize="16sp"
                android:textColor="@color/textPrimary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>